 junit-jupiter-engine;visibility:=reexport,
 junit-jupiter-params;visibility:=reexport,
 junit-platform-launcher;visibility:=reexport,
 junit-platform-engine;visibility:=reexport,
 junit-platform-commons;visibility:=reexport,
 junit-platform-suite-api;visibility:=reexport,
 junit-platform-suite-engine;visibility:=reexport,
 org.mockito.mockito-core;visibility:=reexport,
 org.apache.felix.scr,
 org.jkiss.dbeaver.model,
 org.objenesis;visibility:=reexport,
 net.bytebuddy.byte-buddy;visibility:=reexport,
 net.bytebuddy.byte-buddy-agent;visibility:=reexport
